<%
/**
 * ESEMPIO — pagina di accesso al plugin guestRegister
 * ─────────────────────────────────────────────────────
 * Copia questo file in:  <ital8cms-root>/www/
 *
 * URL di QUESTA pagina (senza globalPrefix):
 *   http://localhost:3000/registraOspiti
 *
 * URL di QUESTA pagina (con globalPrefix = "gestione"):
 *   http://localhost:3000/gestione/registraOspiti
 *
 * URL della pagina del PLUGIN a cui si redirige sotto
 * (default pluginPagesPrefix = "pluginPages"):
 *   http://localhost:3000/pluginPages/guestRegister/registraOspiti.ejs
 *
 * Il plugin deve essere attivo (active: 1) e installato
 * (isInstalled: 1) in pluginConfig.json5, e la cartella
 * di install dentro plugins/ deve chiamarsi "guestRegister".
 *
 * REDIRECT AUTOMATICO
 * Se preferisci che questa pagina reindirizzi direttamente
 * all'interfaccia del plugin senza mostrare nulla,
 * decommentare le due righe seguenti e cancellare
 * il resto del file:
 *
 *   ctx.redirect(passData.globalPrefix + '/pluginPages/guestRegister/registraOspiti.ejs');
 *   return;
 *
 * Se hai personalizzato pluginPagesPrefix in ital8Config.json5,
 * sostituisci "pluginPages" qui sopra e nell'<a href> con il tuo valore.
 */
%>
<!DOCTYPE html>
<html lang="it">

<%- include(passData.themeSys.getThemePartPath('head.ejs')) %>
<title>Registrazione Ospiti</title>
</head>

<body>

<%- include(passData.themeSys.getThemePartPath('header.ejs')) %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 text-center">

      <div class="mb-4">
        <span style="font-size:3rem">🏨</span>
      </div>

      <h1 class="h3 mb-3">Registrazione Ospiti</h1>

      <p class="text-muted mb-4">
        Avvia la procedura di registrazione degli ospiti:<br>
        scansione documenti, completamento dati e generazione<br>
        del file <code>.txt</code> per il portale alloggiati.
      </p>

      <a href="<%= passData.globalPrefix %>/pluginPages/guestRegister/registraOspiti.ejs"
         class="btn btn-primary btn-lg px-5">
        Apri modulo registrazione
      </a>

    </div>
  </div>
</main>

<%- include(passData.themeSys.getThemePartPath('footer.ejs')) %>

</body>
</html>
