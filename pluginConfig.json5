{
  active: 0,           // 1 = plugin attivo, 0 = disabilitato
  isInstalled: 0,      // impostato a 1 automaticamente dopo installPlugin()
  weight: 100,         // priorità di caricamento (bubble sort)
  installedVersion: "0.0.0",

  dependency: {},      // dipendenze da altri plugin ital8cms (da definire)

  nodeModuleDependency: {
    "tesseract.js": "^7.0.0",  // OCR immagini documento
    mrz:            "^5.0.0",  // parsing righe MRZ (ESM-only; caricato con dynamic import())
    "@koa/multer":  "^4.0.0",  // upload multipart in-memory (binding Koa ufficiale di multer)
  },

  custom: {
    // Tipi documento mostrati direttamente nel dropdown del form.
    // Tutti gli altri 90+ tipi restano accessibili tramite "Altro tipo…".
    // Valori: codici portale alloggiati (vedere data/documenti.json).
    documentiComuni: [
      "IDENT",   // Carta d'Identità
      "IDELE",   // Carta Identità Elettronica
      "PASOR",   // Passaporto Ordinario
      "PATEN",   // Patente di Guida
      "PATNA",   // Patente Nautica
      "RIFUG",   // Titolo di Viaggio Rifugiato Politico
    ],
  },
}
