<!DOCTYPE html>
<html lang="it">

<%- include(passData.themeSys.getThemePartPath('head.ejs')) %>
<%- passData.themeSys.injectPluginCss() %>
<%- passData.themeSys.injectPluginJs() %>
<title>Registra Ospiti</title>
</head>

<body class="plugin-page plugin-guestRegister page-registraOspiti">

<%- include(passData.themeSys.getThemePartPath('header.ejs')) %>

<%- passData.themeSys.injectPluginHtmlBefore() %>

<main class="container py-4">

  <!-- Toolbar -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Registra Ospiti</h1>
    <button type="button" class="btn btn-success" id="btnRiepilogo" disabled>
      Riepilogo ed export
    </button>
  </div>

  <!-- Selettore tipo registrazione -->
  <div class="card mb-4 border-primary">
    <div class="card-body py-2">
      <div class="row g-2 align-items-center">
        <div class="col-auto">
          <span class="fw-semibold small">Tipo registrazione:</span>
        </div>
        <div class="col-auto">
          <div class="btn-group" role="group">
            <input type="radio" class="btn-check" name="tipoSoggiorno"
                   id="ts-singolo" value="singolo" checked>
            <label class="btn btn-sm btn-outline-primary" for="ts-singolo">Ospite singolo</label>
            <input type="radio" class="btn-check" name="tipoSoggiorno"
                   id="ts-famiglia" value="famiglia">
            <label class="btn btn-sm btn-outline-primary" for="ts-famiglia">Nucleo familiare</label>
            <input type="radio" class="btn-check" name="tipoSoggiorno"
                   id="ts-gruppo" value="gruppo">
            <label class="btn btn-sm btn-outline-primary" for="ts-gruppo">Gruppo</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Lista ospiti (popolata dinamicamente) -->
  <div id="listaOspiti"></div>

  <!-- Aggiungi ospite -->
  <div class="mt-2 mb-5" id="wrapAggiungi">
    <button type="button" class="btn btn-outline-secondary" id="btnAggiungiOspite">
      + Aggiungi ospite
    </button>
  </div>

  <!-- Modal: Riepilogo e export -->
  <div class="modal fade" id="modalRiepilogo" tabindex="-1"
       aria-labelledby="modalRiepilogoLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title" id="modalRiepilogoLabel">Riepilogo Ospiti</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"
                  aria-label="Chiudi"></button>
        </div>

        <div class="modal-body" id="riepilogoBody">
          <!-- Tabella generata dinamicamente -->
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary"
                  data-bs-dismiss="modal">Chiudi</button>
          <button type="button" class="btn btn-success" id="btnExport">
            Scarica .txt
          </button>
        </div>

      </div>
    </div>
  </div>

</main>

<%- passData.themeSys.injectPluginHtmlAfter() %>

<%- include(passData.themeSys.getThemePartPath('footer.ejs')) %>

<script>
(function () {
  'use strict';

  const API_BASE = '<%= passData.apiPrefix %>/guestRegister';
  const REQUIRED = ['cognome', 'nome', 'sesso', 'dataNascita', 'tipoDocumento', 'numeroDocumento'];

  let guests   = [];
  let nextId   = 1;
  let guestNum = 0;

  // ── DOM helpers ──────────────────────────────────────────────────────────────

  function $id(id)           { return document.getElementById(id); }
  function $card(id)         { return $id(`guest-${id}`); }
  function $campo(id, f)     { return $card(id).querySelector(`.campo[data-field="${f}"]`); }
  function getVal(id, f)     { const el = $campo(id, f); return el ? el.value.trim() : ''; }
  function setVal(id, f, v)  { const el = $campo(id, f); if (el) el.value = v || ''; }

  // ── Guest card HTML ──────────────────────────────────────────────────────────

  function guestCardHTML(guest) {
    const { id, isCapogruppo, num } = guest;

    const badgeCls  = isCapogruppo ? 'bg-primary' : 'bg-secondary';
    const badgeText = isCapogruppo ? 'Capogruppo' : `Ospite ${num}`;
    const removeBtn = isCapogruppo ? '' : `
      <button type="button" class="btn btn-sm btn-outline-danger btn-rimuovi"
              data-id="${id}">✕</button>`;

    function row(cols) {
      return `<div class="row g-2 mb-2">${cols.join('')}</div>`;
    }

    function icon(field) {
      return `<span class="field-icon ms-1" data-field="${field}"></span>`;
    }

    function fieldText(field, label, required, colClass, opts = {}) {
      const star = required ? ' <span class="text-danger">*</span>' : '';
      return `
        <div class="${colClass}">
          <label class="form-label small mb-1">${label}${star} ${icon(field)}</label>
          <input type="${opts.type || 'text'}" class="form-control form-control-sm campo"
            data-id="${id}" data-field="${field}"
            placeholder="${opts.placeholder || ''}"
            ${opts.maxlength ? `maxlength="${opts.maxlength}"` : ''}
            ${opts.style    ? `style="${opts.style}"`          : ''}>
        </div>`;
    }

    function fieldSelect(field, label, required, colClass, options) {
      const star = required ? ' <span class="text-danger">*</span>' : '';
      const opts = options.map(([v, t]) => `<option value="${v}">${t}</option>`).join('');
      return `
        <div class="${colClass}">
          <label class="form-label small mb-1">${label}${star} ${icon(field)}</label>
          <select class="form-select form-select-sm campo"
                  data-id="${id}" data-field="${field}">
            <option value="">—</option>${opts}
          </select>
        </div>`;
    }

    function fieldAc(field, label, endpoint, colClass, opts = {}) {
      return `
        <div class="${colClass}">
          <label class="form-label small mb-1">${label} ${icon(field)}</label>
          <div class="position-relative">
            <input type="text" class="form-control form-control-sm campo ac-input"
              data-id="${id}" data-field="${field}" data-endpoint="${endpoint}"
              ${opts.linkedProv ? `data-linked-prov="${opts.linkedProv}"` : ''}
              placeholder="${opts.placeholder || ''}" autocomplete="off">
            <div class="ac-dropdown dropdown-menu w-100 p-0"></div>
          </div>
        </div>`;
    }

    return `
      <div class="card mb-3 shadow-sm" id="guest-${id}">

        <div class="card-header py-2 d-flex align-items-center gap-2">
          <span class="badge ${badgeCls}">${badgeText}</span>
          <span class="fw-semibold guest-label text-truncate flex-grow-1">—</span>
          <div class="d-flex align-items-center gap-2 flex-shrink-0">
            <div class="scan-status d-none">
              <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            </div>
            <label class="btn btn-sm btn-outline-primary mb-0">
              <input type="file" class="d-none input-file"
                     accept="image/*" capture="environment">
              📷 Scansiona
            </label>
            ${removeBtn}
          </div>
        </div>

        <div class="card-body">

          <div class="alert alert-warning py-2 d-none ocr-alert" role="alert">
            ⚠ Dati parziali — completare i campi evidenziati prima di esportare.
          </div>

          <div class="row g-3">

            <!-- Anteprima documento -->
            <div class="col-md-3 d-flex align-items-start justify-content-center">
              <div class="border rounded d-flex align-items-center justify-content-center
                          bg-light w-100 text-center" style="min-height:200px;overflow:hidden">
                <img class="img-fluid preview-img d-none"
                     style="max-height:220px;object-fit:contain" alt="Anteprima documento">
                <small class="text-muted preview-placeholder px-2">
                  Anteprima<br>documento
                </small>
              </div>
            </div>

            <!-- Campi documento -->
            <div class="col-md-9">

              ${row([
                fieldText('cognome', 'Cognome', true, 'col-12 col-sm-6'),
                fieldText('nome',    'Nome',    true, 'col-12 col-sm-6'),
              ])}

              ${row([
                fieldSelect('sesso', 'Sesso', true, 'col-4 col-sm-2',
                  [['M','M'],['F','F']]),
                fieldText('dataNascita', 'Data nascita', true, 'col-8 col-sm-4',
                  { placeholder: 'GG/MM/AAAA' }),
                fieldSelect('tipoDocumento', 'Tipo doc', true, 'col-6 col-sm-3',
                  [["IDE","Carta d'Identità"],['PAS','Passaporto'],['PAT','Patente']]),
                fieldText('numeroDocumento', 'N° documento', true, 'col-6 col-sm-3',
                  { placeholder: 'Numero' }),
              ])}

              ${row([
                fieldAc('luogoNascita', 'Luogo nascita', 'comuni', 'col-12 col-sm-5',
                  { placeholder: 'Comune', linkedProv: 'provinciaNascita' }),
                fieldText('provinciaNascita', 'Prov', false, 'col-4 col-sm-2',
                  { placeholder: 'PV', maxlength: 2, style: 'text-transform:uppercase' }),
                fieldAc('statoNascita', 'Stato nascita', 'stati', 'col-8 col-sm-5',
                  { placeholder: 'Stato' }),
              ])}

              ${row([
                fieldAc('cittadinanza', 'Cittadinanza', 'stati', 'col-12 col-sm-4',
                  { placeholder: 'Nazionalità' }),
                fieldAc('luogoRilascio', 'Luogo rilascio doc', 'comuni', 'col-12 col-sm-5',
                  { placeholder: 'Comune', linkedProv: 'provinciaRilascio' }),
                fieldText('provinciaRilascio', 'Prov', false, 'col-4 col-sm-1',
                  { placeholder: 'PV', maxlength: 2, style: 'text-transform:uppercase' }),
                fieldAc('statoRilascio', 'Stato rilascio doc', 'stati', 'col-8 col-sm-2',
                  { placeholder: 'Stato' }),
              ])}

              <hr class="my-3">
              <div class="row g-2 align-items-end">
                <div class="col-auto">
                  <span class="fw-semibold small">Soggiorno</span>
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-1">Data arrivo</label>
                  <input type="date" class="form-control form-control-sm campo"
                         data-id="${id}" data-field="dataArrivo">
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-1">Data partenza</label>
                  <input type="date" class="form-control form-control-sm campo"
                         data-id="${id}" data-field="dataPartenza">
                </div>
                ${!isCapogruppo ? `
                <div class="col-auto">
                  <small class="text-muted fst-italic">
                    Pre-compilato dal capogruppo. Modifica se diverso.
                  </small>
                </div>` : ''}
              </div>

            </div>
          </div>
        </div>
      </div>`;
  }

  // ── UI helpers ───────────────────────────────────────────────────────────────

  function updateRiepilogoBtn() {
    $id('btnRiepilogo').disabled = guests.length === 0;
  }

  function updateGuestLabel(id) {
    const c   = getVal(id, 'cognome');
    const n   = getVal(id, 'nome');
    const lbl = $card(id).querySelector('.guest-label');
    if (lbl) lbl.textContent = (c || n) ? `${c} ${n}`.trim() : '—';
  }

  // ── OCR: applica risultato al form ──────────────────────────────────────────

  function applyOcrResult(id, result) {
    const { data, warnings, partial } = result;
    const warnedFields = new Set(warnings.map(w => w.split(':')[0].trim()));
    const allFields = [
      'cognome', 'nome', 'sesso', 'dataNascita', 'tipoDocumento', 'numeroDocumento',
      'luogoNascita', 'provinciaNascita', 'statoNascita', 'cittadinanza',
      'luogoRilascio', 'provinciaRilascio', 'statoRilascio',
    ];

    // Popola campi
    allFields.forEach(f => {
      const el = $campo(id, f);
      if (el && data[f] != null) el.value = data[f];
    });

    // Stato validità e icone su tutti i campi
    allFields.forEach(f => {
      const el   = $campo(id, f);
      const icon = $card(id).querySelector(`.field-icon[data-field="${f}"]`);
      const isReq = REQUIRED.includes(f);

      if (data[f]) {
        if (el && isReq) { el.classList.add('is-valid'); el.classList.remove('is-invalid'); }
        if (icon) { icon.textContent = '✓'; icon.className = 'field-icon ms-1 text-success small'; }
      } else {
        if (el && isReq) { el.classList.add('is-invalid'); el.classList.remove('is-valid'); }
        if (icon && warnedFields.has(f)) {
          icon.textContent = '⚠'; icon.className = 'field-icon ms-1 text-warning small';
        }
      }
    });

    // Banner parziale
    const alertEl = $card(id).querySelector('.ocr-alert');
    if (alertEl) alertEl.classList.toggle('d-none', !partial);

    updateGuestLabel(id);
    updateRiepilogoBtn();
  }

  // ── OCR: scansione file ──────────────────────────────────────────────────────

  async function scanDocument(guest, file) {
    const { id } = guest;
    const card   = $card(id);

    // Preview immediata
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = card.querySelector('.preview-img');
      const ph  = card.querySelector('.preview-placeholder');
      img.src = e.target.result;
      img.classList.remove('d-none');
      if (ph) ph.classList.add('d-none');
    };
    reader.readAsDataURL(file);

    // Spinner on
    card.querySelector('.scan-status').classList.remove('d-none');
    card.querySelector('.input-file').disabled = true;

    try {
      const fd = new FormData();
      fd.append('document', file);
      const res    = await fetch(`${API_BASE}/scanDocument`, { method: 'POST', body: fd });
      const result = await res.json();
      if (!res.ok) throw new Error(result.error || 'Errore OCR');
      applyOcrResult(id, result);
    } catch (err) {
      const alertEl = card.querySelector('.ocr-alert');
      alertEl.textContent = `⚠ Errore scansione: ${err.message}`;
      alertEl.classList.remove('d-none');
    } finally {
      card.querySelector('.scan-status').classList.add('d-none');
      card.querySelector('.input-file').disabled = false;
    }
  }

  // ── Autocomplete ─────────────────────────────────────────────────────────────

  function setupAutocomplete(input) {
    const endpoint   = input.dataset.endpoint;
    const linkedProv = input.dataset.linkedProv;
    const guestId    = input.dataset.id;
    const dropdown   = input.parentElement.querySelector('.ac-dropdown');
    let debounce     = null;

    function close() {
      dropdown.style.display = 'none';
      dropdown.innerHTML     = '';
    }

    function open(items) {
      dropdown.innerHTML = '';
      if (!items.length) { close(); return; }

      items.forEach(item => {
        const a = document.createElement('a');
        a.className = 'dropdown-item py-1 px-2 small';
        a.href      = '#';

        let label = item.nome;
        if (item.provincia) label += ` (${item.provincia})`;
        if (item.cessato)   label += ' — cessato';
        a.textContent = label;
        if (item.cessato) a.style.color = '#999';

        a.addEventListener('mousedown', (e) => {
          e.preventDefault();
          input.value = item.nome;
          input.dispatchEvent(new Event('input', { bubbles: true }));

          // Auto-fill provincia collegata
          if (linkedProv && item.provincia) {
            const provEl = $card(guestId).querySelector(`.campo[data-field="${linkedProv}"]`);
            if (provEl && !provEl.value) provEl.value = item.provincia;
          }
          close();
        });
        dropdown.appendChild(a);
      });

      dropdown.style.display = 'block';
    }

    input.addEventListener('input', () => {
      clearTimeout(debounce);
      const q = input.value.trim();
      if (q.length < 2) { close(); return; }
      debounce = setTimeout(async () => {
        try {
          const res   = await fetch(`${API_BASE}/${endpoint}?q=${encodeURIComponent(q)}`);
          const items = await res.json();
          open(items);
        } catch { close(); }
      }, 300);
    });

    input.addEventListener('blur',    () => setTimeout(close, 200));
    input.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }

  // ── Event setup ──────────────────────────────────────────────────────────────

  function setupGuestEvents(guest) {
    const { id, isCapogruppo } = guest;
    const card = $card(id);

    // File input → scansione
    card.querySelector('.input-file').addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) scanDocument(guest, file);
      e.target.value = '';
    });

    // Autocomplete inputs
    card.querySelectorAll('.ac-input').forEach(setupAutocomplete);

    if (!isCapogruppo) {
      card.querySelector('.btn-rimuovi').addEventListener('click', () => {
        guests = guests.filter(g => g.id !== id);
        card.remove();
        updateRiepilogoBtn();
      });
    }

    ['cognome', 'nome'].forEach(f => {
      const el = $campo(id, f);
      if (el) el.addEventListener('input', () => updateGuestLabel(id));
    });

    // Capogruppo: propaga soggiorno agli ospiti non modificati manualmente
    if (isCapogruppo) {
      ['dataArrivo', 'dataPartenza'].forEach(f => {
        const el = $campo(id, f);
        if (el) el.addEventListener('change', () => propagateSoggiorno(f, el.value));
      });
    } else {
      // Ospite: marca come modificato manualmente se l'utente cambia le date
      ['dataArrivo', 'dataPartenza'].forEach(f => {
        const el = $campo(id, f);
        if (el) el.addEventListener('change', () => { el.dataset.userModified = '1'; });
      });
    }
  }

  // ── Propagazione soggiorno dal capogruppo ────────────────────────────────────

  function propagateSoggiorno(field, value) {
    guests.filter(g => !g.isCapogruppo).forEach(g => {
      const el = $card(g.id)?.querySelector(`.campo[data-field="${field}"]`);
      // Propaga solo se l'ospite non ha modificato manualmente il campo
      if (el && !el.dataset.userModified) el.value = value;
    });
  }

  // ── Add guest ────────────────────────────────────────────────────────────────

  function addGuest(isCapogruppo = false) {
    const guest = { id: nextId++, isCapogruppo, num: isCapogruppo ? 0 : ++guestNum };
    guests.push(guest);
    $id('listaOspiti').insertAdjacentHTML('beforeend', guestCardHTML(guest));
    setupGuestEvents(guest);

    // Pre-compila soggiorno dal capogruppo
    if (!isCapogruppo && guests.length > 1) {
      const capo = guests[0];
      ['dataArrivo', 'dataPartenza'].forEach(f => {
        const capoVal = getVal(capo.id, f);
        if (capoVal) setVal(guest.id, f, capoVal);
      });
    }

    updateRiepilogoBtn();
  }

  // ── Raccoglie i dati del form per un ospite ───────────────────────────────────

  function collectGuest(id) {
    return [
      'cognome', 'nome', 'sesso', 'dataNascita', 'tipoDocumento', 'numeroDocumento',
      'luogoNascita', 'provinciaNascita', 'statoNascita', 'cittadinanza',
      'luogoRilascio', 'provinciaRilascio', 'statoRilascio',
      'dataArrivo', 'dataPartenza',
    ].reduce((obj, f) => { obj[f] = getVal(id, f) || null; return obj; }, {});
  }

  // ── Riepilogo ─────────────────────────────────────────────────────────────────

  function buildRiepilogoTable() {
    const rows = guests.map(g => {
      const d       = collectGuest(g.id);
      const missing = REQUIRED.filter(f => !d[f]);
      const badge   = missing.length
        ? `<span class="badge bg-warning text-dark">⚠ Incompleto</span>`
        : `<span class="badge bg-success">✓ Completo</span>`;
      const label   = g.isCapogruppo ? 'Capogruppo' : `Ospite ${g.num}`;

      return `<tr>
        <td><span class="fw-semibold">${label}</span><br>
            <small class="text-muted">${d.cognome || '—'} ${d.nome || ''}</small></td>
        <td>${d.sesso || '—'}</td>
        <td>${d.dataNascita || '—'}</td>
        <td>${d.tipoDocumento || '—'}<br><small class="text-muted">${d.numeroDocumento || '—'}</small></td>
        <td>${d.dataArrivo || '—'}</td>
        <td>${d.dataPartenza || '—'}</td>
        <td>${badge}${missing.length ? `<br><small class="text-muted">${missing.join(', ')}</small>` : ''}</td>
      </tr>`;
    }).join('');

    return `<div class="table-responsive">
      <table class="table table-sm table-bordered table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Ospite</th><th>Sesso</th><th>Nascita</th>
            <th>Documento</th><th>Arrivo</th><th>Partenza</th><th>Stato</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
  }

  function openRiepilogo() {
    $id('riepilogoBody').innerHTML = buildRiepilogoTable();
    new bootstrap.Modal($id('modalRiepilogo')).show();
  }

  // ── Export .txt ───────────────────────────────────────────────────────────────

  async function exportTxt() {
    const btn       = $id('btnExport');
    const origLabel = btn.textContent;
    btn.disabled    = true;
    btn.textContent = 'Generazione...';

    try {
      const res = await fetch(`${API_BASE}/exportTxt`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ guests: guests.map(g => collectGuest(g.id)) }),
      });
      if (!res.ok) { const e = await res.json(); throw new Error(e.error || 'Errore export'); }

      const blob = await res.blob();
      const url  = URL.createObjectURL(blob);
      const a    = Object.assign(document.createElement('a'), { href: url, download: 'alloggiati.txt' });
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch (err) {
      alert(`Errore: ${err.message}`);
    } finally {
      btn.disabled    = false;
      btn.textContent = origLabel;
    }
  }

  // ── Init ─────────────────────────────────────────────────────────────────────

  function init() {
    addGuest(true);
    $id('btnAggiungiOspite').addEventListener('click', () => addGuest(false));
    $id('btnRiepilogo').addEventListener('click', openRiepilogo);
    $id('btnExport').addEventListener('click', exportTxt);
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>

</body>
</html>
